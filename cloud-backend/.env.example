# Clariti Cloud Backend Environment

# MongoDB
# - Local dev: mongodb://localhost:27017 (run: docker run -p 27017:27017 mongo)
# - Atlas: mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
#   If Atlas SSL fails (TLSV1_ALERT_INTERNAL_ERROR), try: pip install pymongo[tls] --upgrade
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=clariti

# JWT Secret (CHANGE THIS in production)
SECRET_KEY=change-me-in-production

# Server
HOST=0.0.0.0
PORT=8001
