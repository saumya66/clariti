<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Allow JIT compilation (Python runtime needs this) -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- Allow unsigned executable memory (PyInstaller binary) -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Allow loading unsigned dylibs bundled by PyInstaller -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Allow sending Apple Events to other apps (pyautogui automation) -->
  <key>com.apple.security.automation.apple-events</key>
  <true/>
</dict>
</plist>
