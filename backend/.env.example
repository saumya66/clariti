# Clariti Local Backend Environment

# Google Gemini API Key (required for Gemini provider)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# Anthropic Claude API Key (required for Claude provider)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_api_key_here

# Server
HOST=127.0.0.1
PORT=8000

# Cloud backend URL (optional — token is passed per-request from frontend)
CLOUD_API_URL=http://localhost:8001
