# Copy to .env and fill in your values

# Cloud backend URL (used by any API calls)
PUBLIC_API_URL=https://your-cloud-backend.com

# Where the "Book a Demo" CTA links (Cal.com / Calendly / etc.)
PUBLIC_BOOK_DEMO_URL=https://cal.com/clariti/demo

# Demo video shown in the "Watch Demo" modal (YouTube/Loom embed URL or mp4)
PUBLIC_DEMO_VIDEO_URL=
