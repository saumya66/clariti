---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Clariti — QA that thinks.',
  description = 'Clariti is an autonomous QA agent. It sees your app, thinks about what to test, asks when it is unsure, and judges the result — just like your QA would. No test scripts. No selectors. No QA backlog.',
  ogImage = '/og-image.png',
} = Astro.props;

const siteUrl = Astro.site?.href ?? 'https://claritihq.com';
const canonicalUrl = Astro.url.href;
const ogImageAbsolute = new URL(ogImage, siteUrl).href;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Clariti',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS',
  description,
  url: 'https://claritihq.com',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
});
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a0a0f" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Clariti" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Clariti" />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />
    <meta name="twitter:image:alt" content="Clariti" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={jsonLd} />

    <!-- Fonts: Google Sans Flex (primary) + JetBrains Mono (terminal UI) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Google+Sans+Flex:opsz,wght@6..144,1..1000&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body class="bg-[#0a0a0f] antialiased">
    <slot />
  </body>
</html>
