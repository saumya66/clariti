---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Clariti',
  description = 'Clariti is an AI-native QA agent that sees your app, understands it, and runs tests autonomously. It Sees. It Thinks. It Acts. It Judges.',
  ogImage = '/og-image.png',
} = Astro.props;

const siteUrl = Astro.site?.href ?? 'https://claritihq.com';
const canonicalUrl = Astro.url.href;
const ogImageAbsolute = new URL(ogImage, siteUrl).href;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Clariti',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS',
  description,
  url: 'https://claritihq.com',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
});
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#09090b" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Clariti" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Clariti" />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />
    <meta name="twitter:image:alt" content="Clariti" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={jsonLd} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
  </head>
  <body class="bg-[#09090b] antialiased">
    <slot />
  </body>
</html>
